# AI报销材料生成器 - 环境变量配置

# OpenAI API Key（必填）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# API Base URL（可选，用于国内中转或自定义端点）
# 默认值：https://api.openai.com/v1
# 示例（国内中转）：https://api.example.com/v1
OPENAI_API_BASE=https://api.openai.com/v1

# 模型名称（可选）
# 默认值：gpt-4o
# 可选：gpt-4o, gpt-4o-mini, gpt-4-turbo 等
MODEL_NAME=gpt-4o
